# =====================================================================
# CodeInsight Platform .gitignore
# Java 17 + Spring Boot (backend) | React 19 + Vite (frontend)
# =====================================================================

# ---------- Backend (Java / Maven / Spring Boot) ----------
target/
*.class
*.jar
*.war
*.ear
*.log
hs_err_pid*
replay_pid*
build/
out/
.flattened-pom.xml

# Spring Boot devtools
.spring-boot-devtools.properties

# Local H2 / database files
*.db
*.mv.db
*.trace.db

# ---------- Frontend (Node / Vite / React) ----------
node_modules/
dist/
dist-ssr/
*.local
.vite/

# ---------- Environment / Secrets ----------
.env
.env.local
.env.*.local
*.pem
*.key
backend/src/main/resources/application-local.properties

# ---------- Logs ----------
*.log
# Only match top-level logs/ directory; do not collide with source dirs like
# frontend/src/pages/logs/ (which contains the logs page component).
/logs/
pg_run.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------- IDE / Editor ----------
.idea/
.vscode/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
nbproject/private/
nbbuild/
nbdist/
.nb-gradle/

# VS Code (allow workspace-specific settings.json if needed)
!.vscode/settings.json
!.vscode/extensions.json

# ---------- OS ----------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------- Claude Code / AI tooling ----------
.claude/
.mcp.json

# ---------- Test fixtures / local storage ----------
# These are regenerated by the test suite; do not commit.
# 用 /prefix 限定仅匹配仓库根目录，避免误伤 common/storage/ 等 Java 包路径
/storage/
/storage_test/
/temp_repos/
backend/storage/
backend/storage_test/
backend/temp_repos/

# ---------- Coverage / Reports ----------
coverage/
*.lcov
.nyc_output/
.report/
jacoco/
