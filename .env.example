# =====================================================================
# CodeInsight Platform - Environment Variables
# Copy this file to `.env` and fill in real values for local development.
# Backend reads these via `application-local.yml` (see backend/src/main/resources).
# =====================================================================

# ---------- Database (PostgreSQL) ----------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=code_insight
DB_USER=postgres
DB_PASSWORD=postgres

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------- Server ----------
SERVER_PORT=8080

# ---------- LLM / AI ----------
# Set LLM_MOCK=true to use the built-in mock provider (no real API call).
LLM_MOCK=true
LLM_API_KEY=
LLM_API_URL=https://api.minimax.io/v1
LLM_MODEL_NAME=MiniMax-M3

# ---------- Local file storage ----------
STORAGE_LOCAL_PATH=./storage
